<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <remove name="Access-Control-Allow-Origin" />
        <remove name="Access-Control-Allow-Headers" />
        <remove name="Access-Control-Allow-Credentials" />
        <!--
					Replace value="*" to value="https://innovator.site" (where "innovator.site" is domain name of deployed Innovator)
					in the header below to allow browser requests only from "innovator.site" and thus prevent potential CSRF attacks.
				-->
        <add name="Access-Control-Allow-Origin" value="*" />
        <add name="Access-Control-Allow-Credentials" value="true" />
        <add name="Access-Control-Allow-Headers" value="content-disposition,content-range,content-type,locale,soapaction,timezone_name,transactionid,vaultid,Aras-Content-Range-Checksum-Type,Aras-Content-Range-Checksum,Authorization,X-Aras-Authorization,traceparent,tracestate" />
        <add name="X-Content-Type-Options" value="nosniff" />
      </customHeaders>
    </httpProtocol>
    <handlers>
      <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
    </handlers>
    <aspNetCore processPath=".\bin\Aras.Server.exe" requestTimeout="01:00:00" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="outofprocess">
      <environmentVariables>
        <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        <!-- Use "Development" for errors diagnostics. -->
        <environmentVariable name="DOTNET_ADDITIONAL_DEPS" value="Plugins\additionalDeps\" />
        <environmentVariable name="DOTNET_SHARED_STORE" value="Plugins\store\" />
      <environmentVariable name="ASPNETCORE_FORWARDEDHEADERS_ENABLED" value="true" /></environmentVariables>
    </aspNetCore>
  </system.webServer>
</configuration>